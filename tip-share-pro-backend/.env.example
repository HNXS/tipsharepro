# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tipsharepro?schema=public"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Redis (optional, for caching)
REDIS_URL="redis://localhost:6379"

# Stripe (for payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (SendGrid)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# CORS
ALLOWED_ORIGINS="http://localhost:3000"

# Logging
LOG_LEVEL="info"
