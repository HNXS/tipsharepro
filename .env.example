# ============================================================================
# TipSharePro - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
POSTGRES_PASSWORD=your-secure-database-password

# ============================================================================
# pgAdmin (Database Admin UI)
# ============================================================================
PGADMIN_EMAIL=admin@tipsharepro.com
PGADMIN_PASSWORD=your-secure-pgadmin-password

# ============================================================================
# Backend API Configuration
# ============================================================================

# JWT Secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# JWT Token Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS - Allowed Origins (comma-separated for multiple)
ALLOWED_ORIGINS=https://app.tipsharepro.com

# ============================================================================
# Frontend Configuration (Build-time)
# ============================================================================

# API URL - Use /api for proxied requests via Next.js rewrites
NEXT_PUBLIC_API_URL=/api

# ============================================================================
# Frontend Configuration (Runtime)
# ============================================================================

# Internal backend URL for Next.js rewrites (Docker service name)
BACKEND_INTERNAL_URL=http://backend:3001
